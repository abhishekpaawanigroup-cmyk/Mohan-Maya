# ─────────────────────────────────────────────────────────────
# Frontend environment
# Copy to ".env" and restart `npm run dev`.
# NOTE: Vite only exposes vars prefixed with VITE_ to the browser, so NO
# API keys/secrets go here — those live only in the Backend's .env.
# ─────────────────────────────────────────────────────────────

# Base URL of the backend API (the Express app in ../Backend).
# Defaults to http://localhost:5000 if not set.
VITE_API_URL=http://localhost:5000
